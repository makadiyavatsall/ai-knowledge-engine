APP_NAME=Gmail RAG API
DEBUG=true

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gmail_rag

CORS_ORIGINS=http://localhost:3000
DB_CHECK_ON_STARTUP=true

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Application JWT (min 32 characters; generate with: openssl rand -hex 32)
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret-at-least-32-chars

# Separate Fernet key for Google token encryption at rest (must differ from JWT_SECRET_KEY)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=replace-with-fernet-generate-key-output

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Session cookie (JWT stored here after OAuth — not in URL)
AUTH_COOKIE_NAME=access_token
# false for local HTTP; must be true when DEBUG=false
AUTH_COOKIE_SECURE=false

# Post-OAuth redirect (must be listed in ALLOWED_FRONTEND_REDIRECT_URLS)
FRONTEND_OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback
ALLOWED_FRONTEND_REDIRECT_URLS=http://localhost:3000/auth/callback

OAUTH_STATE_MAX_AGE_SECONDS=600

# Gmail sync (synchronous MVP)
GMAIL_SYNC_MAX_MESSAGES=50
GMAIL_API_REQUEST_TIMEOUT_SECONDS=30

# Token-based chunking (tiktoken cl100k_base)
CHUNK_SIZE=500
CHUNK_OVERLAP=100
